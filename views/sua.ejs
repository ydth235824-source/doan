<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .card {
            border: none;
            border-radius: 15px;
        }

        .card-header {
            border-radius: 15px 15px 0 0 !important;
        }
    </style>
</head>

<body>
    <%- include('navbar') %>
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card shadow-lg">
                        <div class="card-header bg-warning text-dark py-3">
                            <h4 class="mb-0 text-center fw-bold">
                                <i class="bi bi-pencil-square"></i> CHỈNH SỬA SINH VIÊN
                            </h4>
                        </div>
                        <div class="card-body p-4">
                            <form action="/sua/<%= sv._id %>" method="POST">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Mã Số Sinh Viên (MSSV)</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                                        <input type="text" name="MSSV" class="form-control" value="<%= sv.MSSV %>"
                                            pattern="[A-Za-z]{3}\d{6}"
                                            title="MSSV phải gồm 3 chữ và 6 số (VD: DTH235824)" required>
                                    </div>
                                    <small class="text-danger">* Lưu ý: Kiểm tra kỹ định dạng 3 chữ 6 số trước khi cập nhật.</small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Họ Và Tên</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                                        <input type="text" name="HoTen" class="form-control" value="<%= sv.HoTen %>" required>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Lớp Sinh Hoạt</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-mortarboard"></i></span>
                                        <select name="Lop" class="form-select" required>
                                            <option value="">-- Chọn lớp --</option>
                                            <% danhSachLop.forEach(l=> { %>
                                                <option value="<%= l.MaLop %>" <%=sv.Lop===l.MaLop ? 'selected' : '' %>>
                                                    <%= l.TenLop %> (<%= l.MaLop %>)
                                                </option>
                                            <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold">Khoa</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-building"></i></span>
                                        <select name="Khoa" class="form-select" required>
                                            <option value="">-- Chọn khoa --</option>
                                            <% danhSachKhoa.forEach(k => { %>
                                                <option value="<%= k.TenKhoa %>" <%= sv.Khoa === k.TenKhoa ? 'selected' : '' %>>
                                                    <%= k.TenKhoa %>
                                                </option>
                                            <% }) %>
                                        </select>
                                    </div>
                                </div>

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                        <i class="bi bi-check-circle"></i> CẬP NHẬT NGAY
                                    </button>
                                    <a href="/" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>